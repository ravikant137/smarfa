# Twilio (or replacement) setup for SMS alerts
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
FARMER_PHONE_NUMBERS=+10000000000,+10000000001

# tuning
GROWTH_RATE_MIN=0.05
INTRUSION_MOTION_THRESHOLD=1

# sqlite (fallback)
SMARTFARM_DB=sqlite:///./smarfa.db
